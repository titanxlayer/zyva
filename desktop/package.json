{
  "name": "zyva-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "ZYVA — the AI IDE that never forgets",
  "homepage": "https://github.com/titanxlayer/zyva",
  "author": { "name": "titanxlayer", "email": "dev@titanxlayer.com" },
  "main": "main.js",
  "scripts": {
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.titanxlayer.zyva",
    "productName": "ZYVA",
    "files": ["main.js"],
    "extraResources": [
      { "from": "../.next/standalone", "to": ".next/standalone" },
      { "from": "../.next/static", "to": ".next/standalone/.next/static" },
      { "from": "../public", "to": ".next/standalone/public" }
    ],
    "win": { "target": ["nsis"] },
    "linux": {
      "target": ["deb", "AppImage"],
      "category": "Development",
      "maintainer": "titanxlayer <dev@titanxlayer.com>"
    },
    "mac": { "target": ["dmg"] }
  }
}
