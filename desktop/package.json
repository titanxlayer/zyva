{
  "name": "zyva-desktop",
  "version": "0.3.0",
  "private": true,
  "description": "ZYVA — the AI IDE that never forgets",
  "homepage": "https://github.com/titanxlayer/zyva",
  "author": { "name": "titanxlayer", "email": "dev@titanxlayer.com" },
  "repository": { "type": "git", "url": "https://github.com/titanxlayer/zyva.git" },
  "main": "main.js",
  "scripts": {
    "prepackage": "node prepackage.mjs",
    "dist": "node prepackage.mjs && electron-builder --publish never"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.titanxlayer.zyva",
    "productName": "ZYVA",
    "icon": "build/icon.png",
    "files": ["main.js"],
    "extraResources": [
      { "from": "../.next/standalone", "to": ".next/standalone" }
    ],
    "win": { "target": ["nsis"], "icon": "build/icon.png" },
    "linux": {
      "target": ["deb", "AppImage"],
      "category": "Development",
      "icon": "build/icon.png",
      "maintainer": "titanxlayer <dev@titanxlayer.com>"
    },
    "mac": { "target": ["dmg"], "icon": "build/icon.png" }
  }
}
