# ZYVA Embedding Gateway config
PORT=8090

# Upstream embedding backend: "dashscope" (cloud Qwen, CPU VPS ok) or "tei" (self-hosted model)
ZYVA_EMBED_UPSTREAM=dashscope

# DashScope (used when upstream=dashscope)
DASHSCOPE_BASE=https://dashscope-intl.aliyuncs.com
DASHSCOPE_API_KEY=

# TEI self-hosted model (used when upstream=tei) — e.g. HF text-embeddings-inference
TEI_URL=

ZYVA_RERANK_MODEL=qwen3-rerank

# Client auth (comma-separated keys). Leave empty for open/dev.
ZYVA_GATEWAY_KEYS=
# Per-key daily embedding quota (0 = unlimited)
ZYVA_GATEWAY_DAILY_QUOTA=0
# Max cached vectors in memory
ZYVA_GATEWAY_CACHE_MAX=50000
