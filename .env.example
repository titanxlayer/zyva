# ── Auth (NextAuth.js) ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://app.zyva.dev

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/zyva

# Workspace isolation root
ZYVA_WORKSPACES_ROOT=/opt/zyva-cloud/workspaces

# ── Primary inference: 0G Private Computer (TEE-attested) ────────────────────
# Get your key at: https://pc.0g.ai
OG_PC_API_KEY=
OG_PC_BASE_URL=https://pc.0g.ai/v1
# Available: minimax-m3 | glm-5.1 | qwen3.7-max | qwen3.6-plus | deepseek-v4-pro
OG_PC_MODEL=minimax-m3

# ── E2B sandbox (build/install tasks only — not dev server) ──────────────────
# Get your key at: https://e2b.dev
E2B_API_KEY=

# ── Fallback reasoning (local testing / stress tests only) ───────────────────
CEREBRAS_API_KEY=

# ── Embeddings + rerank (Alibaba DashScope — international region) ───────────
DASHSCOPE_API_KEY=
DASHSCOPE_BASE=https://dashscope-intl.aliyuncs.com

# Embedding / retrieval config
ZYVA_EMBED_MODEL=text-embedding-v4
ZYVA_EMBED_DIMS=1024
ZYVA_RERANK_MODEL=qwen3-rerank
ZYVA_VISION_EMBED_MODEL=tongyi-embedding-vision-flash

# Vector store: "local" or "qdrant"
ZYVA_VECTOR_STORE=local
QDRANT_URL=
QDRANT_API_KEY=

# ── Observability (optional Langfuse) ────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=

# ── Execution security ───────────────────────────────────────────────────────
ZYVA_EXEC_TIMEOUT_MS=15000
ZYVA_AUTORUN_COMMANDS=false
